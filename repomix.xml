}
function IconQuote() {
  return (
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3.691 6.292C5.094 4.771 7.217 4 10 4h1v2.819l-.804.161c-1.37.274-2.323.813-2.833 1.604A2.902 2.902 0 0 0 6.925 10H10a1 1 0 0 1 1 1v7c0 1.103-.897 2-2 2H3a1 1 0 0 1-1-1v-5l.003-2.919c-.009-.101-.04-1.01.205-2.16.175-.862.589-1.780 1.483-2.629zM20 4h1v2.819l-.804.161c-1.37.274-2.323.813-2.833 1.604A2.902 2.902 0 0 0 16.925 10H20a1 1 0 0 1 1 1v7c0 1.103-.897 2-2 2h-6a1 1 0 0 1-1-1v-5l.003-2.919c-.009-.101-.04-1.01.205-2.16.175-.862.589-1.780 1.483-2.629C15.094 4.771 17.217 4 20 4z" />
    </svg>
