'use client';

import React, { useRef, useEffect, useMemo, useCallback, KeyboardEvent, ClipboardEvent } from 'react';
import hljs from 'highlight.js/lib/common';
import { ParsedBlock } from '@/lib/markdownTransform';
import { parseInlineMarkdown, parseTableMarkdown } from '@/lib/markdownTransform';

interface EditorBlockProps {
  block: ParsedBlock;
  isFirst: boolean;
  isFocused: boolean;
  onFocus: (id: string) => void;
  onBlur: () => void;
  onTextChange: (id: string, text: string) => void;
  onEnter: (id: string, currentText: string, caretOffset: number) => void;
  onBackspaceEmpty: (id: string) => void;
  onArrow: (id: string, dir: 'up' | 'down') => void;
  onImagePaste: (id: string, file: File) => boolean;
  onMarkdownPaste: (id: string, text: string) => boolean;
  onCodeLanguageChange: (id: string, language: string) => void;
  onClearDocument: () => void;
  onUndo: () => void;
  onRedo: () => void;
  registerRef: (id: string, el: HTMLElement | null) => void;
}

const CODE_LANGUAGES = [
  'auto',
  'plaintext',
  'javascript',
  'typescript',
  'python',
  'bash',
  'json',
  'markdown',
  'html',
  'css',
  'sql',
  'go',
  'rust',
  'java',
  'c',
  'cpp',
  'yaml',
];

const LANGUAGE_LABELS: Record<string, string> = {
  auto: 'Auto',
  plaintext: 'Plain text',
  javascript: 'JavaScript',
  typescript: 'TypeScript',
  python: 'Python',
  bash: 'Bash',
  json: 'JSON',
  markdown: 'Markdown',
  html: 'HTML',
  css: 'CSS',
  sql: 'SQL',
  go: 'Go',
  rust: 'Rust',
  java: 'Java',
  c: 'C',
  cpp: 'C++',
  yaml: 'YAML',
};

// Block type → HTML tag mapping
const TAG_MAP: Partial<Record<string, string>> = {
  h1: 'h1', h2: 'h2', h3: 'h3', h4: 'h4', h5: 'h5', h6: 'h6',
  p: 'p', quote: 'blockquote', code: 'pre',
  ul: 'li', ol: 'li',
};

const PLACEHOLDER_MAP: Record<string, string> = {
  h1: 'Heading 1',
  h2: 'Heading 2',
  h3: 'Heading 3',
  h4: 'Heading 4',
  h5: 'Heading 5',
  h6: 'Heading 6',
  p: 'Write something…',
  quote: 'Quote…',
  code: 'Code…',
  ul: 'List item…',
  ol: 'List item…',
};

const MARKDOWN_PASTE_HINT = /(^#{1,6}\s)|(^>\s?)|(^[-*+]\s)|(^\d+\.\s)|(```)|(^\|.*\|$)|(!\[[^\]]*\]\([^\)]+\))|(\[[^\]]+\]\([^\)]+\))|(~{2}.+~{2})|(\*\*.+\*\*)|(\*[^*]+\*)/m;

export const EditorBlock = React.memo(function EditorBlock({
  block,
  isFirst,
  isFocused,
  onFocus,
  onBlur,
  onTextChange,
  onEnter,
  onBackspaceEmpty,
  onArrow,
  onImagePaste,
  onMarkdownPaste,
  onCodeLanguageChange,
  onClearDocument,
  onUndo,
  onRedo,
  registerRef,
}: EditorBlockProps) {
  const elRef = useRef<HTMLElement | null>(null);
  const isComposingRef = useRef(false);
  const lastTextRef = useRef(block.text);
  const skipNextBlurSyncRef = useRef(false);

  useEffect(() => {
    lastTextRef.current = block.text;
  }, [block.text]);

  // Register ref with parent
  const setRef = useCallback(
    (el: HTMLElement | null) => {
      elRef.current = el;
      registerRef(block.id, el);
    },
    [block.id, registerRef]
  );

  // Table block — rendered as static HTML
  if (block.type === 'table') {
    return (
      <div
        className="editor-content my-4"
        dangerouslySetInnerHTML={{ __html: parseTableMarkdown(block.text) }}
        onClick={() => onFocus(block.id)}
      />
    );
  }

  const tag = TAG_MAP[block.type] || 'p';
  const placeholder = isFirst && block.type === 'h1'
    ? 'What are we writing today?'
    : PLACEHOLDER_MAP[block.type] ?? 'Write something…';

  // Key down handler
  const handleKeyDown = useCallback(
    (e: KeyboardEvent<HTMLElement>) => {
      if (isComposingRef.current) return;

      const el = elRef.current;
      if (!el) return;
      const text = el.textContent ?? '';
      const mod = e.ctrlKey || e.metaKey;

      if (mod && e.key.toLowerCase() === 'z') {
        e.preventDefault();
        if (e.shiftKey) {
          onRedo();
        } else {
          onUndo();
        }
        return;
      }

      if (mod && e.key.toLowerCase() === 'y') {
        e.preventDefault();
        onRedo();
        return;
      }

      if (mod && e.key.toLowerCase() === 'a') {
        e.preventDefault();
        const sel = window.getSelection();
        if (!sel) return;

        const range = sel.rangeCount > 0 ? sel.getRangeAt(0) : null;
        const fullTextLength = text.length;
        const isInsideCurrentBlock =
          !!range && el.contains(range.startContainer) && el.contains(range.endContainer);
        const selectedLength = range?.toString().length ?? 0;
        const isWholeBlockSelected =
          isInsideCurrentBlock && selectedLength === fullTextLength && fullTextLength > 0;

        if (!isWholeBlockSelected) {
          const blockRange = document.createRange();
          blockRange.selectNodeContents(el);
          sel.removeAllRanges();
          sel.addRange(blockRange);
          return;
        }

        const editorDoc = el.closest('[data-editor-doc="true"]');
        if (editorDoc) {
          const docRange = document.createRange();
          docRange.selectNodeContents(editorDoc);
          sel.removeAllRanges();
          sel.addRange(docRange);
        }
        return;
      }

      if (e.key === 'Backspace' || e.key === 'Delete') {
        const sel = window.getSelection();
        if (sel && !sel.isCollapsed && sel.rangeCount > 0) {
          const editorDoc = el.closest('[data-editor-doc="true"]');
          if (editorDoc) {
            const range = sel.getRangeAt(0);
            const docRange = document.createRange();
            docRange.selectNodeContents(editorDoc);

            const isWithinDoc =
              editorDoc.contains(range.startContainer) &&
              editorDoc.contains(range.endContainer);
            const isWholeDocSelected =
              isWithinDoc &&
              range.toString().length > 0 &&
              range.toString().length === docRange.toString().length;

            if (isWholeDocSelected) {
              e.preventDefault();
              onClearDocument();
              return;
            }
          }
        }
      }

      if (e.key === 'Enter' && !e.shiftKey) {
        if (block.type === 'code') {
          // In code blocks Enter should insert a newline, not create a new content block.
          return;
        }

        const sel = window.getSelection();
        let caretOffset = text.length;
        if (sel && sel.rangeCount > 0) {
          const range = sel.getRangeAt(0);
          const preCaretRange = range.cloneRange();
          preCaretRange.selectNodeContents(el);
          preCaretRange.setEnd(range.startContainer, range.startOffset);
          caretOffset = preCaretRange.toString().length;
        }

        skipNextBlurSyncRef.current = true;
        e.preventDefault();
        onEnter(block.id, text, caretOffset);
        return;
      }

      if (e.key === 'Backspace' && text === '') {
        e.preventDefault();
        onBackspaceEmpty(block.id);
        return;
      }

      if (e.key === 'ArrowUp') {
        // Check if cursor is at the very start of the element
        const sel = window.getSelection();
        if (sel?.anchorOffset === 0) {
          e.preventDefault();
          onArrow(block.id, 'up');
        }
        return;
      }

      if (e.key === 'ArrowDown') {
        const sel = window.getSelection();
        const len = el.textContent?.length ?? 0;
        if (sel?.anchorOffset === len) {
          e.preventDefault();
          onArrow(block.id, 'down');
        }
        return;
      }
    },
    [block.id, block.type, onEnter, onBackspaceEmpty, onArrow, onClearDocument, onUndo, onRedo]
  );

  // Input handler — fires after the DOM has been updated by the browser
  const handleInput = useCallback(() => {
    if (isComposingRef.current) return;
    const el = elRef.current;
    if (!el) return;
    const text = el.textContent ?? '';
    if (text !== lastTextRef.current) {
      lastTextRef.current = text;
      onTextChange(block.id, text);
    }
  }, [block.id, onTextChange]);

  const highlightedCodeHtml = useMemo(() => {
    const code = block.text || '';
    const language = (block.language || 'plaintext').toLowerCase();
    if (!code) return '';
    try {
      if (language !== 'plaintext' && hljs.getLanguage(language)) {
        return hljs.highlight(code, { language }).value;
      }
      return hljs.highlightAuto(code).value;
    } catch {
      return code
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }
  }, [block.text, block.language]);

  // Paste handler
  const handlePaste = useCallback(
    (e: ClipboardEvent<HTMLElement>) => {
      // Check for image files
      const items = Array.from(e.clipboardData?.items ?? []);
      const imageItem = items.find((item) => item.type.startsWith('image/'));
      if (imageItem) {
        e.preventDefault();
        const file = imageItem.getAsFile();
        if (file) onImagePaste(block.id, file);
        return;
      }

      // Check for text — try to detect if it's markdown
      const text = e.clipboardData?.getData('text/plain') ?? '';
      const looksLikeMarkdown =
        text.includes('\n') ||
        MARKDOWN_PASTE_HINT.test(text);

      if (text && looksLikeMarkdown) {
        e.preventDefault();
        if (onMarkdownPaste(block.id, text)) return;
      }

      if (!text) {
        return;
      }

      // Default: let browser handle plain text paste
      // Prevent rich HTML paste
      if (e.clipboardData?.getData('text/html')) {
        e.preventDefault();
        document.execCommand('insertText', false, text);
      }
    },
    [block.id, onImagePaste, onMarkdownPaste]
  );

  // Block type → CSS class
  const getBlockClass = () => {
    const base = 'editor-block outline-none';
    switch (block.type) {
      case 'h1': return `${base} is-h1`;
      case 'h2': return `${base} is-h2`;
      case 'h3': return `${base} is-h3`;
      case 'h4': return `${base} is-h4`;
      case 'h5': return `${base} is-h5`;
      case 'h6': return `${base} is-h6`;
      case 'quote': return `${base} is-quote`;
      case 'code': return `${base} is-code`;
      case 'ul': return `${base} is-ul`;
      case 'ol': return `${base} is-ol`;
      default: return base;
    }
  };

  // Inline HTML for rendering inline markdown
  // We only render inline HTML for non-editable preview; for editing,
  // the contenteditable shows plain text.
  // When NOT focused, we show rendered HTML. When focused, we show raw text.
  const shouldShowRendered = !isFocused && block.type !== 'code' && block.text.trim();

  const renderedHtml = shouldShowRendered ? parseInlineMarkdown(block.text) : undefined;

  useEffect(() => {
    const el = elRef.current;
    if (!el || shouldShowRendered) return;

    // Keep editable DOM text in sync with source block text.
    // Only hydrate while not focused (or when an editable block starts empty)
    // so typing does not reset the caret to the start.
    const shouldHydrate = !isFocused || ((el.textContent ?? '') === '' && block.text.length > 0);
    if (shouldHydrate && (el.textContent ?? '') !== block.text) {
      el.textContent = block.text;
    }
  }, [block.text, shouldShowRendered, isFocused]);

  const commonProps = {
    ref: setRef as React.Ref<never>,
    contentEditable: true as const,
    suppressContentEditableWarning: true,
    className: getBlockClass(),
    'data-placeholder': placeholder,
    'data-block-id': block.id,
    onFocus: () => onFocus(block.id),
    onBlur: () => {
      onBlur();

      if (skipNextBlurSyncRef.current) {
        skipNextBlurSyncRef.current = false;
        return;
      }

      // On blur, re-sync text from DOM
      const el = elRef.current;
      if (el) {
        const text = el.textContent ?? '';
        if (text !== lastTextRef.current) {
          lastTextRef.current = text;
          onTextChange(block.id, text);
        }
      }
    },
    onKeyDown: handleKeyDown,
    onInput: handleInput,
    onPaste: handlePaste,
    onCompositionStart: () => { isComposingRef.current = true; },
    onCompositionEnd: () => {
      isComposingRef.current = false;
      handleInput();
    },
    // When rendering inline HTML (not focused), we set dangerouslySetInnerHTML
    // When focused or empty, we just set text content
    ...(shouldShowRendered
      ? { dangerouslySetInnerHTML: { __html: renderedHtml } }
      : {}),
    // Suppress warning for controlled/uncontrolled mismatch
  };

  // Wrap list items in appropriate container
  if (block.type === 'ul') {
    return (
      <ul style={{ paddingLeft: '1.5em', listStyleType: 'disc' }}>
        {React.createElement(tag, commonProps as never)}
      </ul>
    );
  }
  if (block.type === 'ol') {
    return (
      <ol style={{ paddingLeft: '1.5em', listStyleType: 'decimal' }}>
        {React.createElement(tag, commonProps as never)}
      </ol>
    );
  }

  if (block.type === 'code') {
    const selectedLanguage = (block.language || 'auto').toLowerCase();
    return (
      <div className="editor-code-wrap">
        <div className="editor-code-header">
          <label className="editor-code-language-pill" onMouseDown={(e) => e.stopPropagation()}>
            <span className="editor-code-language-dot" aria-hidden="true" />
            <select
              value={selectedLanguage}
              onChange={(e) => onCodeLanguageChange(block.id, e.target.value === 'auto' ? '' : e.target.value)}
              className="editor-code-language-select"
              aria-label="Code language"
            >
              {CODE_LANGUAGES.map((language) => (
                <option key={language} value={language}>
                  {LANGUAGE_LABELS[language] ?? language}
                </option>
              ))}
            </select>
          </label>
        </div>

        {isFocused ? (
          <pre
            ref={setRef as React.Ref<never>}
            contentEditable
            suppressContentEditableWarning
            className="editor-block is-code"
            data-placeholder={placeholder}
            data-block-id={block.id}
            onFocus={() => onFocus(block.id)}
            onBlur={() => {
              onBlur();
              const el = elRef.current;
              if (el) {
                const text = el.textContent ?? '';
                if (text !== lastTextRef.current) {
                  lastTextRef.current = text;
                  onTextChange(block.id, text);
                }
              }
            }}
            onKeyDown={handleKeyDown}
            onInput={handleInput}
            onPaste={handlePaste}
            onCompositionStart={() => {
              isComposingRef.current = true;
            }}
            onCompositionEnd={() => {
              isComposingRef.current = false;
              handleInput();
            }}
          />
        ) : (
          <pre
            className="editor-block is-code hljs"
            data-block-id={block.id}
            onClick={() => onFocus(block.id)}
          >
            <code dangerouslySetInnerHTML={{ __html: highlightedCodeHtml }} />
          </pre>
        )}
      </div>
    );
  }

  if (block.type === 'hr') {
    return <hr style={{ borderTop: '1px solid var(--border-default)', margin: '1.5em 0' }} />;
  }

  return React.createElement(tag, commonProps as never);
});
