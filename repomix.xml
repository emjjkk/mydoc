  --text-muted: #a09e98;
  --text-placeholder: #c4c2bb;
  --text-inverse: #ffffff;

  --border-default: rgba(0, 0, 0, 0.08);
  --border-strong: rgba(0, 0, 0, 0.15);

  --accent: #2563eb;
  --accent-hover: #1d4ed8;

  --shadow-toolbar: 0 4px 24px rgba(0, 0, 0, 0.1), 0 1px 4px rgba(0, 0, 0, 0.06);
  --shadow-modal: 0 20px 60px rgba(0, 0, 0, 0.15);
  --shadow-sidebar: 4px 0 24px rgba(0, 0, 0, 0.06);
}

/* ── DARK THEME ── */
[data-theme="dark"] {
  --bg-app: #141413;
  --bg-editor: #111110;
  --bg-sidebar: #111110;
  --bg-toolbar: #111110;
  --bg-modal: #1e1d1b;
  --bg-hover: rgba(255, 255, 255, 0.05);
  --bg-active: rgba(255, 255, 255, 0.1);
  --bg-topbar: #111110;

  --text-primary: #e8e6e1;
  --text-secondary: #8a8880;
  --text-muted: #5a5854;
  --text-placeholder: #3d3c39;
  --text-inverse: #141413;

  --border-default: rgba(255, 255, 255, 0.06);
  --border-strong: rgba(255, 255, 255, 0.12);

  --accent: #60a5fa;
  --accent-hover: #93c5fd;

  --shadow-toolbar: 0 4px 24px rgba(0, 0, 0, 0.4), 0 1px 4px rgba(0, 0, 0, 0.2);
  --shadow-modal: 0 20px 60px rgba(0, 0, 0, 0.5);
  --shadow-sidebar: 4px 0 24px rgba(0, 0, 0, 0.3);
}

/* ── SEPIA THEME ── */
[data-theme="sepia"] {
  --bg-app: #f5f0e8;
  --bg-editor: #ede8dc;
  --bg-sidebar: #ede8dc;
  --bg-toolbar: #ede8dc;
  --bg-modal: #faf7f2;
  --bg-hover: rgba(0, 0, 0, 0.04);
  --bg-active: rgba(0, 0, 0, 0.08);
  --bg-topbar: #ede8dc;

  --text-primary: #2c2416;
  --text-secondary: #7a6b52;
  --text-muted: #a8957a;
  --text-placeholder: #c9b99a;
  --text-inverse: #faf7f2;

  --border-default: rgba(0, 0, 0, 0.07);
  --border-strong: rgba(0, 0, 0, 0.14);

  --accent: #8b5e3c;
  --accent-hover: #6d4a2e;

  --shadow-toolbar: 0 4px 24px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
  --shadow-modal: 0 20px 60px rgba(0, 0, 0, 0.12);
  --shadow-sidebar: 4px 0 24px rgba(0, 0, 0, 0.05);
}

/* ─────────────────────────────────────────
   BASE RESETS
───────────────────────────────────────── */

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  height: 100%;
  font-family: var(--font-ui);
  background: var(--bg-app);
  color: var(--text-primary);
  transition: background 0.2s ease, color 0.2s ease;
  -webkit-font-smoothing: antialiased;
}

/* ─────────────────────────────────────────
   EDITOR CONTENT STYLES
───────────────────────────────────────── */

.editor-content {
  font-family: var(--font-editor);
  color: var(--text-primary);
  font-size: 1.04rem;
  line-height: 1.72;
  outline: none;
  min-height: 100%;
}

/* Block-level elements */
.editor-content h1 {
  font-size: 2em;
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 0.45em;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.editor-content h2 {
  font-size: 1.58em;
  font-weight: 600;
  line-height: 1.24;
  margin-top: 1.35em;
  margin-bottom: 0.34em;
  letter-spacing: -0.015em;
}

.editor-content h3 {
  font-size: 1.22em;
  font-weight: 600;
  line-height: 1.3;
  margin-top: 1.1em;
  margin-bottom: 0.3em;
}

.editor-content h4 {
  font-size: 1em;
  font-weight: 600;
  margin-top: 0.9em;
  margin-bottom: 0.22em;
}

.editor-content h5 {
  font-size: 0.9em;
  font-weight: 600;
  margin-top: 0.85em;
  margin-bottom: 0.2em;
  color: var(--text-secondary);
}

.editor-content h6 {
  font-size: 0.83em;
  font-weight: 600;
  margin-top: 0.85em;
  margin-bottom: 0.2em;
  color: var(--text-muted);
}

.editor-content p {
  margin-bottom: 0.75em;
}

.editor-content blockquote {
  border-left: 3px solid var(--accent);
  padding: 0.45em 1.05em;
  margin: 0.95em 0;
  color: var(--text-secondary);
  font-style: italic;
  background: var(--bg-hover);
  border-radius: 0 6px 6px 0;
}

.editor-content ul {
  padding-left: 1.5em;
  margin-bottom: 0.75em;
  list-style-type: disc;
}

.editor-content ol {
  padding-left: 1.5em;
  margin-bottom: 0.75em;
  list-style-type: decimal;
}

.editor-content li {
  margin-bottom: 0.16em;
}

.editor-content code {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 0.875em;
  background: var(--bg-active);
  padding: 0.15em 0.4em;
  border-radius: 4px;
  color: var(--accent);
}

.editor-content pre {
  background: var(--bg-active);
  border-radius: 8px;
  padding: 1.25em;
  overflow-x: auto;
  margin: 1.25em 0;
}

.editor-content pre code {
  background: none;
  padding: 0;
  font-size: 0.875em;
  color: var(--text-primary);
}

.editor-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.25em 0;
  font-size: 0.9em;
}

.editor-content table th {
  background: var(--bg-hover);
  font-weight: 600;
  padding: 0.6em 1em;
  text-align: left;
  border: 1px solid var(--border-strong);
}

.editor-content table td {
  padding: 0.5em 1em;
  border: 1px solid var(--border-default);
}

.editor-content table tr:nth-child(even) {
  background: var(--bg-hover);
}

.editor-content img {
  max-width: 100%;
  border-radius: 8px;
  margin: 1em 0;
  display: block;
}

.editor-content a {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.editor-content hr {
  border: none;
  border-top: 1px solid var(--border-default);
  margin: 2em 0;
}

.editor-content strong { font-weight: 700; }
.editor-content em { font-style: italic; }
.editor-content s, .editor-content del { text-decoration: line-through; color: var(--text-muted); }

/* Task list */
.editor-content input[type="checkbox"] {
  margin-right: 0.5em;
  accent-color: var(--accent);
}

/* ─────────────────────────────────────────
   EDITOR BLOCK (contenteditable div approach)
───────────────────────────────────────── */

.editor-block {
  outline: none;
  min-height: 1.72em;
  position: relative;
  margin-bottom: 0.9em;
}

.editor-block.is-h1 { font-size: 2.18em; font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; }
.editor-block.is-h2 { font-size: 1.72em; font-weight: 600; line-height: 1.24; letter-spacing: -0.015em; }
.editor-block.is-h3 { font-size: 1.33em; font-weight: 600; line-height: 1.3; }
.editor-block.is-h4 { font-size: 1.08em; font-weight: 600; }
.editor-block.is-h5 { font-size: 0.98em; font-weight: 600; color: var(--text-secondary); }
.editor-block.is-h6 { font-size: 0.9em; font-weight: 600; color: var(--text-muted); }
.editor-block.is-quote {
  border-left: 3px solid var(--accent);
  padding: 0.45em 1.05em;
  font-style: italic;
  color: var(--text-secondary);
  background: var(--bg-hover);
  border-radius: 0 6px 6px 0;
}
.editor-block.is-code {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 0.92em;
  background: var(--bg-active);
  border-radius: 6px;
  padding: 0.9em 1em;
  white-space: pre;
  overflow-x: auto;
  max-width: 100%;
}
.editor-block.is-ul { padding-left: 1.5em; list-style-type: disc; display: list-item; }
.editor-block.is-ol { padding-left: 1.5em; list-style-type: decimal; display: list-item; }

.editor-code-wrap {
  margin-bottom: 0.7em;
}

.editor-code-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 0.35em;
}

.editor-code-language-pill {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  border: 1px solid var(--border-default);
  background: var(--bg-editor);
  border-radius: 999px;
  padding: 4px 10px;
}

.editor-code-language-dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: var(--accent);
  opacity: 0.85;
}

.editor-code-language-select {
  border: none;
  background: transparent;
  color: var(--text-primary);
  border-radius: 6px;
  font-size: 12px;
  font-family: var(--font-ui);
  font-weight: 500;
  padding: 0;
  outline: none;
  cursor: pointer;
}

.editor-code-language-select:focus {
  outline: none;
}

.editor-block.is-code code {
  display: block;
  min-width: max-content;
  white-space: pre;
}

.hljs {
  background: transparent;
  color: var(--text-primary);
}

.hljs-keyword,
.hljs-selector-tag,
.hljs-title,
.hljs-section,
.hljs-doctag,
.hljs-name,
.hljs-strong {
  color: #f97316;
}

.hljs-string,
.hljs-attr,
.hljs-template-tag,
.hljs-template-variable,
.hljs-addition {
  color: #10b981;
}

.hljs-number,
.hljs-literal,
.hljs-symbol,
.hljs-bullet,
.hljs-variable,
.hljs-quote,
.hljs-code {
  color: #22c55e;
}

.hljs-comment,
.hljs-meta,
.hljs-deletion {
  color: var(--text-muted);
}

/* Empty placeholder */
.editor-block[data-placeholder]:empty::before {
  content: attr(data-placeholder);
  color: var(--text-placeholder);
  pointer-events: none;
  position: absolute;
  left: 0;
}

.editor-block.is-h1[data-placeholder]:empty::before {
  font-size: inherit;
}

/* ─────────────────────────────────────────
   SCROLLBARS
───────────────────────────────────────── */

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* ─────────────────────────────────────────
   TRANSITIONS
───────────────────────────────────────── */

.sidebar-enter { transform: translateX(-100%); }
.sidebar-enter-active { transform: translateX(0); transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1); }
.sidebar-exit { transform: translateX(0); }
.sidebar-exit-active { transform: translateX(-100%); transition: transform 0.18s ease-in; }

/* Modal backdrop */
.modal-backdrop {
  backdrop-filter: blur(4px);
  background: rgba(0, 0, 0, 0.4);
}
[data-theme="dark"] .modal-backdrop {
  background: rgba(0, 0, 0, 0.6);
}

/* ─────────────────────────────────────────
   SELECTION
───────────────────────────────────────── */

::selection {
  background: color-mix(in srgb, var(--accent) 25%, transparent);
}

/* ─────────────────────────────────────────
   UTILITY CLASSES
───────────────────────────────────────── */

.glass {
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 6px;
  border: none;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: background 0.12s ease, color 0.12s ease;
  font-family: var(--font-ui);
}

.icon-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.icon-btn.active {
  background: var(--bg-active);
  color: var(--accent);
}
</file>

