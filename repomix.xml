}

interface OptionChipProps {
  label: string;
  subtitle?: string;
  isActive: boolean;
  onClick: () => void;
  preview?: React.ReactNode;
}

function OptionChip({ label, subtitle, isActive, onClick, preview }: OptionChipProps) {
  return (
    <button
      onClick={onClick}
